# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=afl_cognitive
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
# Optional CA cert path for managed MySQL
# DB_SSL_CA=C:/path/to/ca.pem

# Set to true to use SQLite instead of MySQL (no local MySQL required)
USE_SQLITE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
